<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Sunil Das | Portfolio</title>
    <style>
        /* Modern CSS Reset & Variables */
        :root {
            --primary-color: #2563eb;       /* Modern blue accent */
            --primary-dark: #1d4ed8;
            --bg-dark: #0f172a;           /* Deep slate background */
            --bg-card: #1e293b;           /* Slate card background */
            --text-main: #f8fafc;         /* Crisp white */
            --text-muted: #94a3b8;        /* Soft gray */
            --border-color: #334155;
            --max-width: 1100px;
            --font-stack: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, Helvetica, Arial, sans-serif;
        }

        * {
            box-sizing: border-box;
            margin: 0;
            padding: 0;
        }

        html {
            scroll-behavior: smooth;
        }

        body {
            font-family: var(--font-stack);
            background-color: var(--bg-dark);
            color: var(--text-main);
            line-height: 1.6;
        }

        /* Container helper */
        .container {
            max-width: var(--max-width);
            margin: 0 auto;
            padding: 0 2rem;
        }

        /* Header & Navigation */
        header {
            position: sticky;
            top: 0;
            background-color: rgba(15, 23, 42, 0.9);
            backdrop-filter: blur(12px);
            border-bottom: 1px solid var(--border-color);
            z-index: 1000;
        }

        .nav-container {
            display: flex;
            justify-content: space-between;
            align-items: center;
            height: 70px;
        }

        .logo {
            font-size: 1.3rem;
            font-weight: 700;
            color: var(--text-main);
            text-decoration: none;
            letter-spacing: -0.5px;
        }

        .logo span {
            color: var(--primary-color);
        }

        .nav-links {
            display: flex;
            gap: 2rem;
            list-style: none;
        }

        .nav-links a {
            color: var(--text-muted);
            text-decoration: none;
            font-weight: 500;
            transition: color 0.2s ease;
            font-size: 0.95rem;
        }

        .nav-links a:hover {
            color: var(--primary-color);
        }

        /* Hero Section */
        #hero {
            padding: 8rem 0 6rem 0;
            display: flex;
            align-items: center;
            min-height: calc(100vh - 70px);
        }

        .hero-content {
            max-width: 800px;
        }

        .badge {
            display: inline-block;
            background-color: rgba(37, 99, 235, 0.15);
            color: var(--primary-color);
            padding: 0.4rem 1rem;
            border-radius: 20px;
            font-size: 0.85rem;
            font-weight: 600;
            margin-bottom: 1.5rem;
            border: 1px solid rgba(37, 99, 235, 0.3);
        }

        h1 {
            font-size: 3.5rem;
            font-weight: 800;
            line-height: 1.15;
            letter-spacing: -1px;
            margin-bottom: 1.5rem;
        }

        h1 span {
            color: var(--primary-color);
        }

        .hero-subtitle {
            font-size: 1.25rem;
            color: var(--text-muted);
            margin-bottom: 2.5rem;
            max-width: 650px;
        }

        .btn-group {
            display: flex;
            gap: 1rem;
        }

        .btn {
            display: inline-block;
            padding: 0.8rem 1.8rem;
            border-radius: 8px;
            font-weight: 600;
            text-decoration: none;
            transition: all 0.2s ease;
            cursor: pointer;
        }

        .btn-primary {
            background-color: var(--primary-color);
            color: white;
        }

        .btn-primary:hover {
            background-color: var(--primary-dark);
        }

        .btn-secondary {
            background-color: transparent;
            color: var(--text-main);
            border: 1px solid var(--border-color);
        }

        .btn-secondary:hover {
            background-color: var(--border-color);
        }

        /* General Section Formatting */
        section {
            padding: 6rem 0;
            border-top: 1px solid var(--border-color);
        }

        .section-title {
            font-size: 2rem;
            font-weight: 700;
            margin-bottom: 3rem;
            position: relative;
        }

        .section-title::after {
            content: '';
            position: absolute;
            bottom: -8px;
            left: 0;
            width: 50px;
            height: 4px;
            background-color: var(--primary-color);
            border-radius: 2px;
        }

        /* Grid Layouts (Skills & Work) */
        .skills-grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
            gap: 1.5rem;
        }

        .skill-card {
            background-color: var(--bg-card);
            padding: 2rem;
            border-radius: 12px;
            border: 1px solid var(--border-color);
            transition: transform 0.2s ease, border-color 0.2s ease;
        }

        .skill-card:hover {
            transform: translateY(-4px);
            border-color: var(--primary-color);
        }

        .skill-card h3 {
            font-size: 1.2rem;
            margin-bottom: 1rem;
            color: var(--text-main);
        }

        .skill-card ul {
            list-style: none;
        }

        .skill-card li {
            color: var(--text-muted);
            margin-bottom: 0.5rem;
            font-size: 0.95rem;
            display: flex;
            align-items: center;
        }

        .skill-card li::before {
            content: "▹";
            color: var(--primary-color);
            margin-right: 8px;
            font-weight: bold;
        }

        /* Experience Timeline */
        .timeline {
            display: flex;
            flex-direction: column;
            gap: 2rem;
        }

        .timeline-item {
            background-color: var(--bg-card);
            border: 1px solid var(--border-color);
            border-radius: 12px;
            padding: 2.5rem;
            position: relative;
        }

        .timeline-header {
            display: flex;
            justify-content: space-between;
            align-items: flex-start;
            flex-wrap: wrap;
            gap: 1rem;
            margin-bottom: 1.5rem;
        }

        .timeline-title h3 {
            font-size: 1.4rem;
            color: var(--text-main);
        }

        .timeline-title h4 {
            font-size: 1.1rem;
            color: var(--primary-color);
            font-weight: 500;
        }

        .timeline-date {
            background-color: rgba(255, 255, 255, 0.05);
            padding: 0.3rem 0.8rem;
            border-radius: 6px;
            font-size: 0.85rem;
            color: var(--text-muted);
            border: 1px solid var(--border-color);
        }

        .timeline-body ul {
            list-style: none;
        }

        .timeline-body li {
            color: var(--text-muted);
            margin-bottom: 0.75rem;
            padding-left: 1.25rem;
            position: relative;
            font-size: 0.95rem;
        }

        .timeline-body li::before {
            content: "•";
            position: absolute;
            left: 0;
            color: var(--primary-color);
            font-size: 1.2rem;
        }

        /* Education & Certifications Split Grid */
        .edu-cert-grid {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 3rem;
        }

        .edu-list, .cert-list {
            display: flex;
            flex-direction: column;
            gap: 1.5rem;
        }

        .info-card {
            background-color: var(--bg-card);
            border: 1px solid var(--border-color);
            border-radius: 12px;
            padding: 1.5rem 2rem;
        }

        .info-card h3 {
            font-size: 1.15rem;
            margin-bottom: 0.25rem;
        }

        .info-card h4 {
            font-size: 0.95rem;
            color: var(--primary-color);
            font-weight: 500;
            margin-bottom: 0.5rem;
        }

        .info-meta {
            font-size: 0.85rem;
            color: var(--text-muted);
        }

        /* Contact Section */
        .contact-box {
            background-color: var(--bg-card);
            border: 1px solid var(--border-color);
            border-radius: 12px;
            padding: 3rem;
            text-align: center;
            max-width: 700px;
            margin: 0 auto;
        }

        .contact-box h3 {
            font-size: 1.8rem;
            margin-bottom: 1rem;
        }

        .contact-box p {
            color: var(--text-muted);
            margin-bottom: 2rem;
        }

        .contact-details {
            display: flex;
            justify-content: center;
            gap: 2rem;
            flex-wrap: wrap;
        }

        .contact-link {
            color: var(--text-main);
            text-decoration: none;
            font-weight: 600;
            font-size: 1.05rem;
            transition: color 0.2s ease;
        }

        .contact-link:hover {
            color: var(--primary-color);
        }

        /* Footer */
        footer {
            padding: 3rem 0;
            border-top: 1px solid var(--border-color);
            text-align: center;
            color: var(--text-muted);
            font-size: 0.9rem;
        }

        /* Responsive Breakpoints */
        @media (max-width: 900px) {
            .edu-cert-grid {
                grid-template-columns: 1fr;
                gap: 2.5rem;
            }
        }

        @media (max-width: 768px) {
            h1 {
                font-size: 2.5rem;
            }
            .nav-links {
                display: none;
            }
            #hero {
                padding: 6rem 0 4rem 0;
            }
            .timeline-header {
                flex-direction: column;
                gap: 0.5rem;
            }
            .timeline-date {
                align-self: flex-start;
            }
        }
    </style>
</head>
